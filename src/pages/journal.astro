---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostListWithThumbnails from '../components/PostListWithThumbnails.astro';
import { getCollection } from 'astro:content';

// Get all blog posts and sort them by date
const allPosts = await getCollection('posts');
const sortedPosts = allPosts.sort((a, b) => {
  return new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf();
});

// Format posts for the PostList component
const posts = sortedPosts.map(post => ({
  ...post,
  url: `/posts/${post.id}`,
  frontmatter: post.data
}));
---

<BaseLayout title="Blog">
  <div class="max-w-3xl mx-auto">
    <header class="mb-12 text-center" transition:animate="fade">
      <h1 class="text-7xl mb-8 font-bold text-black dark:bg-gradient-to-r dark:from-green-400 dark:to-cyan-400 dark:bg-clip-text dark:text-transparent">Blog</h1>
      <p class="text-xl text-muted-foreground">
        My ideas and reflections on things relating to digital education and technology. While I work in Higher Education, the content I post here is based upon my personal views and not that of my employer.
      </p>
    </header>

    <div transition:animate="fade">
      <PostListWithThumbnails posts={posts} showTags={true} title="All Posts" />
    </div>
  </div>
</BaseLayout>
